#include <windows.h>

#define IDC_LIST 1001

100 DIALOGEX 0, 0, 300, 400
STYLE WS_CAPTION | WS_SYSMENU | DS_CENTER
CAPTION "Process Killer"
FONT 8, "MS Shell Dlg"
BEGIN
    LISTBOX IDC_LIST, 10, 10, 280, 340, LBS_NOTIFY | WS_BORDER | WS_VSCROLL
    DEFPUSHBUTTON "Terminate Selected", IDOK, 100, 360, 80, 25
    PUSHBUTTON "Cancel", IDCANCEL, 200, 360, 60, 25
END

101 DIALOGEX 0, 0, 500, 400
STYLE WS_CAPTION | WS_SYSMENU | DS_CENTER
CAPTION "Service Manager"
FONT 8, "MS Shell Dlg"
BEGIN
    LISTBOX IDC_LIST, 10, 10, 480, 340, LBS_NOTIFY | WS_BORDER | WS_VSCROLL
    DEFPUSHBUTTON "Manage Selected", IDOK, 180, 360, 100, 25
    PUSHBUTTON "Refresh", IDCANCEL, 300, 360, 80, 25
END
